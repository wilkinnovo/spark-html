node_modules
dist
# Exception: the committed single-file runtime bundle (M3.1 plan §5.1).
# `main`/`exports` point here; fresh clones resolve it without a build step.
# `prepublishOnly` regenerates it before each publish so the registry never
# ships a stale bundle. Everything else named `dist` stays ignored (templates,
# examples, build caches).
!packages/spark/dist/
!packages/spark/dist/**

# Root .md files (except README.md and benchmarks.md, the committed perf
# ledger the website/docs cite) — design notes, not public docs
/*.md
!/README.md
!/benchmarks.md

# Playwright e2e artifacts
test-results
playwright-report
.last-run.json

# E2E template scaffolding (serve-template-for-e2e.mjs)
/tmp-e2e-tpl-*

# Bug tracking notes (internal, not for version control)
packages/spark-html-router/bugs.md

# Generated by website/scripts/gen-stats.js before dev/build.
website/src/stats.js
bench/krausest/profile/components/
/tmp-e2e-reloc-*
e2e/fixtures/cookbook/*/node_modules
website/public/components/cookbook.html
