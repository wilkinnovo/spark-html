{
  "name": "spark-html",
  "version": "1.6.0",
  "description": "Get your spark back. HTML that reacts!.",
  "homepage": "https://wilkinnovo.github.io/spark-html",
  "type": "module",
  "main": "./dist/spark.js",
  "types": "./src/index.d.ts",
  "bin": {
    "spark-html": "./bin/cli.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./dist/spark.js"
    },
    "./globals": {
      "types": "./src/globals.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "bin"
  ],
  "scripts": {
    "build": "node ../../scripts/build-dist.mjs",
    "prepublishOnly": "node ../../scripts/build-dist.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wilkinnovo/spark-html.git"
  },
  "keywords": [
    "reactive",
    "html",
    "components",
    "framework",
    "no-build"
  ],
  "license": "MIT"
}
