{
  "name": "spark-prerender",
  "version": "1.0.0-rc.2",
  "description": "Build-time prerender (SEO) for spark-html — reuses the real runtime, no SSR server, no app-code changes.",
  "type": "module",
  "main": "./src/prerender.js",
  "types": "./src/prerender.d.ts",
  "homepage": "https://wilkinnovo.github.io/spark-html",
  "exports": {
    ".": {
      "types": "./src/prerender.d.ts",
      "default": "./src/prerender.js"
    },
    "./bun": {
      "default": "./src/bun.js"
    }
  },
  "bin": {
    "spark-prerender": "bin/cli.js"
  },
  "scripts": {
    "test": "node test/prerender.js && node test/hydrate.js && node test/props-slots.js && node test/robustness.js && node test/routes.js && node test/cli.js"
  },
  "files": [
    "src",
    "bin"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wilkinnovo/spark-html.git",
    "directory": "packages/spark-prerender"
  },
  "dependencies": {
    "linkedom": "^0.18.12"
  },
  "keywords": [
    "spark-html",
    "prerender",
    "ssg",
    "seo",
    "static"
  ],
  "license": "MIT",
  "peerDependencies": {
    "spark-html": ">=1.0.0-rc.1 <2"
  }
}
