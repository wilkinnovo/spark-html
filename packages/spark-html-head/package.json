{
  "name": "spark-html-head",
  "version": "1.0.0",
  "description": "Reactive document <title> and <meta> per route for spark-html — one line, no dependencies.",
  "type": "module",
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "homepage": "https://wilkinnovo.github.io/spark-html",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    },
    "./ssr": {
      "types": "./src/ssr.d.ts",
      "default": "./src/ssr.js"
    }
  },
  "scripts": {
    "test": "node test/head.js"
  },
  "files": [
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wilkinnovo/spark-html.git",
    "directory": "packages/spark-html-head"
  },
  "keywords": [
    "spark-html",
    "head",
    "title",
    "meta",
    "seo",
    "router"
  ],
  "license": "MIT",
  "peerDependencies": {
    "spark-html": ">=1.0.0 <2"
  }
}
